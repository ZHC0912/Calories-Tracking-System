# Copy to .env and fill in. Never commit .env (it is gitignored).

# --- Phase 1: analysis engine ---
# FoodData Central API key (free: https://fdc.nal.usda.gov/api-key-signup).
# Optional — without it, nutrient lookups serve from data/usda_cache.json only.
USDA_API_KEY=
STORAGE_DIR=./uploads
MODEL_BACKEND=stub
USDA_CACHE_PATH=./data/usda_cache.json

# --- Phase 2: persistence and auth ---
# SQLAlchemy URL. SQLite (default) needs no server; Postgres example below.
DATABASE_URL=sqlite:///./calories.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/calories
# Secret used to sign JWTs. Generate a long random value for any real deploy,
# e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MIN=60
